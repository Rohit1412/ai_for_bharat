{
  "name": "climateai-lambda",
  "version": "2.0.0",
  "description": "ClimateAI AWS Lambda backend (TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@aws-sdk/*",
    "dev": "ts-node src/index.ts",
    "zip": "npm run build && cd dist && zip -r ../lambda.zip index.js",
    "deploy": "npm run zip && aws lambda update-function-code --function-name climateai-backend --zip-file fileb://lambda.zip --region ap-south-1"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-sns": "^3.600.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
