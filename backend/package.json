{
  "name": "climateai-backend",
  "version": "2.0.0",
  "description": "ClimateAI AWS backend — Lambda + setup scripts (TypeScript)",
  "private": true,
  "scripts": {
    "setup:dynamo": "ts-node scripts/setup-dynamodb.ts",
    "setup:s3": "ts-node scripts/setup-s3.ts",
    "setup:sns": "ts-node scripts/setup-sns.ts",
    "setup:all": "npm run setup:dynamo && npm run setup:s3 && npm run setup:sns",
    "lambda:build": "cd lambda && npm install && npm run build",
    "lambda:deploy": "cd lambda && npm run deploy"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-sns": "^3.600.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
