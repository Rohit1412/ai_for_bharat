# Environment Variables Template
# Copy this to .env and fill in your values

# AWS Configuration
AWS_REGION=ap-south-1
AWS_PROFILE=viriva

# AWS Bedrock (Claude 3.5 Sonnet)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=ap-south-1

# Frontend API Endpoint (set after deployment)
VITE_API_URL=http://localhost:3000
VITE_MAPBOX_TOKEN=pk_test_your_mapbox_token_here

# Cognito Configuration (auto-populated by Amplify)
VITE_AWS_USER_POOLS_ID=ap-south-1_xxxxx
VITE_AWS_USER_POOLS_WEB_CLIENT_ID=xxxxx
VITE_AWS_COGNITO_REGION=ap-south-1

# DynamoDB Configuration
DYNAMODB_REGION=ap-south-1
DYNAMODB_TABLE_FARMS=viriva-farms-dev
DYNAMODB_TABLE_ALERTS=viriva-alerts-dev
DYNAMODB_TABLE_INTERVENTIONS=viriva-interventions-dev

# S3 Configuration
S3_BUCKET_DATA=viriva-data-dev
S3_BUCKET_PDFS=viriva-exports-dev

# SNS Configuration
SNS_TOPIC_ALERTS=arn:aws:sns:ap-south-1:xxxxxxxxxxxx:viriva-alerts-dev

# Feature Flags
ENABLE_SATELLITE_SYNC=true
ENABLE_BEDROCK_RAG=true
ENABLE_ALERTS=true
DEBUG=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
