AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID

BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022

DYNAMODB_ALERTS_TABLE=viriva-alerts
DYNAMODB_INTERVENTIONS_TABLE=viriva-interventions
DYNAMODB_ACTION_PLANS_TABLE=viriva-action-plans

S3_BUCKET_NAME=viriva-climate-data

