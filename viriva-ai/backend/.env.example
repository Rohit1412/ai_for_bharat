COGNITO_USER_POOL_ID=YOUR_USER_POOL_ID
COGNITO_CLIENT_ID=YOUR_CLIENT_ID

API_GATEWAY_ENDPOINT=https://YOUR_API_ID.execute-api.ap-south-1.amazonaws.com/prod

CORS_ALLOWED_ORIGINS=http://localhost:5173,https://main.dxxxxxxxx.amplifyapp.com

LOG_LEVEL=INFO
