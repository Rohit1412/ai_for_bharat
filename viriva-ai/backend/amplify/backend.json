{
  "version": "1",
  "backend": {
    "default": {
      "name": "viriva",
      "region": "ap-south-1"
    }
  },
  "auth": {
    "default": {
      "userPoolName": "viriva-userpool",
      "autoVerifiedAttributes": ["email"],
      "mfaConfiguration": "OPTIONAL",
      "mfaTypes": ["TOTP", "SMS"]
    }
  },
  "api": {
    "viriva": {
      "service": "AppSync",
      "providerPlugin": "awscloudformation",
      "output": {
        "authConfig": [
          {
            "defaultAuthentication": {
              "authenticationType": "AWS_IAM"
            }
          },
          {
            "userPoolAuthentication": {
              "userPoolId": "Cognito_UserPool_ID"
            }
          }
        ]
      }
    }
  },
  "storage": {
    "viriva_bucket": {
      "service": "S3",
      "providerPlugin": "awscloudformation"
    }
  },
  "notifications": {
    "viriva_sns": {
      "service": "SNS",
      "providerPlugin": "awscloudformation"
    }
  }
}
