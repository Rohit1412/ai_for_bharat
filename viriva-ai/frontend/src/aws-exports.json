{
  "version": "1.0",
  "auth": {
    "region": "ap-south-1",
    "userPoolId": "COGNITO_USER_POOL_ID",
    "userPoolWebClientId": "COGNITO_CLIENT_ID",
    "identityPoolId": "COGNITO_IDENTITY_POOL_ID",
    "identityPoolRegion": "ap-south-1",
    "allowUnauthenticatedIdentities": false,
    "oauth": {}
  },
  "api": {
    "endpoints": [
      {
        "name": "virivaapi",
        "endpoint": "https://API_ID.execute-api.ap-south-1.amazonaws.com/prod",
        "region": "ap-south-1",
        "service": "apigateway"
      }
    ]
  },
  "analytics": {
    "amazon_pinpoint": {
      "region": "ap-south-1",
      "app_id": "PINPOINT_APP_ID"
    }
  },
  "storage": {
    "s3": {
      "bucket": "viriva-climate-data",
      "region": "ap-south-1",
      "identityPoolId": "COGNITO_IDENTITY_POOL_ID"
    }
  },
  "notifications": {
    "channels": {
      "SNS": [
        {
          "key": "Default",
          "resource": "arn:aws:sns:ap-south-1:ACCOUNT_ID:viriva-climate-alerts"
        }
      ]
    }
  }
}
